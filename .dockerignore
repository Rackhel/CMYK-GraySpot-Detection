# Git
.git
.gitignore
.gitattributes

# Python virtual environments
.venv
venv
env/
ENV/
env.bak/
venv.bak/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# Dataset (don't copy large data into image - mount at runtime)
data/
*.zip
*.tar
*.gz
*.7z
*.rar

# Logs
*.log
logs/

# OS files
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo

# IDE files
.vscode/
.idea/
*.sublime-*

# Notebooks (usually too large for Docker image)
*.ipynb
.ipynb_checkpoints/

# Build artifacts
dist/
build/
*.egg-info/
*.egg

# Docker files (don't need in image)
Dockerfile
.dockerignore
docker-compose.yml

# Config files (if they contain secrets)
.env
*.env
config.local.yaml

# Temporary files
tmp/
temp/
*.bak
*.tmp

# Project specific
notebooks/  # If you have notebooks folder
tests/      # Tests don't need to be in production image