# 데이터 폴더 — 파일은 무시하되 폴더 구조(.gitkeep)는 유지 / data folder(google download images)
data_set/*
!data_set/images/
data_set/images/*
!data_set/images/.gitkeep

# 출력 폴더 - 파일은 무시하되 폴더 구조(.gitkeep)는 유지 / output folder
outputs/*
!outputs/reports
!outputs/baseline
!outputs/optuna
outputs/reports/*
outputs/baseline/*
outputs/optuna/*
!outputs/reports/.gitkeep
!outputs/baseline/.gitkeep
!outputs/optuna/.gitkeep


# 압축 파일 / zip file
*.zip

# Python 캐시 / python cashe
__pycache__/
*.pyc
*.pyo

# 가상환경 / virtual machine
.venv/
venv/
env/

# 학습 결과물 / train reports
*.pt
*.onnx
*.mlmodel

# macOS
.DS_Store

# IDE
.vscode/
.idea/

# 로그 파일 / log files
*.log

# 기타 / others
*.tmp
*.bak

# 빌드 결과물 / build artifacts
dist/
build/

# 테스트 결과물 / test artifacts
test_outputs/

# 개인 설정 파일 / personal config files
*.env
.claude/